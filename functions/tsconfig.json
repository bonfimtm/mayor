{
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "compileOnSave": true,
  "include": [
    "src"
  ]
}
