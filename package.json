{
  "name": "mayor",
  "version": "0.0.0",
  "license": "GPL-3.0",
  "repository": "https://github.com/bonfimtm/mayor.git",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0 || >=24.0.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host=0.0.0.0",
    "build:img": "./convert-images.sh 'src/assets/images/*'",
    "prebuild": "npm run build:img",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "predeploy": "npm run build",
    "deploy": "firebase deploy --only hosting",
    "cleanall": "rm -rf node_modules dist"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.4",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.4",
    "bootstrap": "^4.6.2",
    "firebase": "^12.15.0",
    "font-awesome": "^4.7.0",
    "jquery": "^3.7.1",
    "popper.js": "^1.16.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^9.0.0",
    "@types/jquery": "^4.0.1",
    "angular-eslint": "^22.0.0",
    "eslint": "^9.0.0",
    "firebase-tools": "^15.0.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
