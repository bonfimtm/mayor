{
  "name": "mayor",
  "version": "0.0.0",
  "license": "GPL-3.0",
  "repository": "https://github.com/bonfimtm/mayor.git",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host=0.0.0.0",
    "build:img": "./convert-images.sh 'src/assets/images/*'",
    "prebuild": "npm run build:img",
    "build": "ng build --prod",
    "lint": "ng lint",
    "predeploy": "npm run prerender",
    "deploy": "firebase deploy --only hosting",
    "cleanall": "rm -rf node_modules dist",
    "dev:ssr": "ng run mayor:serve-ssr",
    "serve:ssr": "node dist/mayor/server/main.js",
    "build:ssr": "NODE_OPTIONS=--openssl-legacy-provider ng build --prod && NODE_OPTIONS=--openssl-legacy-provider ng run mayor:server:production",
    "preprerender": "npm run build:img",
    "prerender": "npm run build:ssr && node prerender.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~10.2.0",
    "@angular/common": "~10.2.0",
    "@angular/compiler": "~10.2.0",
    "@angular/core": "~10.2.0",
    "@angular/fire": "^6.0.3",
    "@angular/forms": "~10.2.0",
    "@angular/platform-browser": "~10.2.0",
    "@angular/platform-browser-dynamic": "~10.2.0",
    "@angular/platform-server": "~10.2.0",
    "@angular/router": "~10.2.0",
    "@nguniversal/express-engine": "^10.1.0",
    "bootstrap": "^4.5.3",
    "express": "^4.15.2",
    "firebase": "^7.13.1",
    "font-awesome": "^4.7.0",
    "jquery": "^3.5.1",
    "popper.js": "^1.16.1",
    "rxjs": "~6.6.0",
    "tslib": "^2.0.0",
    "zone.js": "~0.10.2"
  },
  "devDependencies": {
    "@angular-devkit/architect": ">= 0.900 < 0.1100",
    "@angular-devkit/build-angular": "~0.1002.0",
    "@angular/cli": "~10.2.0",
    "@angular/compiler-cli": "~10.2.0",
    "@nguniversal/builders": "^10.1.0",
    "@types/express": "^4.17.9",
    "@types/express-serve-static-core": "^4.17.14",
    "@types/jasmine": "~3.5.0",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^12.11.1",
    "@types/serve-static": "^1.13.9",
    "codelyzer": "^6.0.0",
    "firebase-tools": "^8.0.0",
    "fuzzy": "^0.1.3",
    "inquirer": "^6.2.2",
    "inquirer-autocomplete-prompt": "^1.0.1",
    "open": "^7.0.3",
    "ts-node": "~8.3.0",
    "tslint": "~6.1.0",
    "typescript": "~4.0.2"
  }
}
